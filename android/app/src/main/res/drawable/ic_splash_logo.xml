<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen logo (Fix A: black splash screen).

  Vector drawable used by @drawable/splash_screen. Drawn in dark color
  (#1A1A1A) so it is highly visible against the bright white splash
  background, on both phone and car displays.

  The logo is a stylized "EVDx" lightning bolt — a simplified version of
  the app icon. The path fills a 108x108 viewport with the design centered.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer rounded square background (transparent — splash bg shows through) -->

    <!-- Lightning bolt shape (stylized "E" for EVDx / EV diagnosis) -->
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M62,16 L34,58 L50,58 L42,92 L74,46 L56,46 L62,16 Z" />

    <!-- Small accent dot (the "x" of EVDx) -->
    <path
        android:fillColor="#00D2FF"
        android:pathData="M84,72 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 Z" />
</vector>
