<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen logo — the EVDx app icon (E + lightning bolt + D).

  Converted from public/app-icon.svg. This is the main app icon that
  clearly shows:
    - Letter E on the left (cyan, 3 horizontal bars + vertical bar)
    - Lightning bolt in the middle (cyan/blue, replaces V)
    - Letter D on the right (purple)
    - "EVDx" text below (light gray)

  The original SVG uses linear gradients and a glow filter which Android
  vector drawables don't fully support. This version uses solid colors
  that match the gradient midpoints:
    - E and bolt: #29B6F6 (cyan, midpoint of cyanGrad)
    - D: #512DA8 (purple, midpoint of purpleGrad)
    - Text: #CCCCCC (light gray)

  On the white splash background (#FFFFFF), all three colors are clearly
  visible and professional. The E + bolt + D composition is the brand
  identity used on the app icon, website, and documentation.

  Viewport: 1024 x 1024 (matches app-icon.svg), sized at 108dp x 108dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <!-- Letter E: 3 horizontal bars + left vertical bar (cyan) -->
    <!-- Top bar of E -->
    <path
        android:fillColor="#29B6F6"
        android:pathData="M332,325 L442,325 L442,349 L332,349 Z" />
    <!-- Middle bar of E -->
    <path
        android:fillColor="#29B6F6"
        android:pathData="M332,408 L417,408 L417,432 L332,432 Z" />
    <!-- Bottom bar of E -->
    <path
        android:fillColor="#29B6F6"
        android:pathData="M332,491 L442,491 L442,515 L332,515 Z" />
    <!-- Left vertical bar of E -->
    <path
        android:fillColor="#29B6F6"
        android:pathData="M332,325 L356,325 L356,515 L332,515 Z" />

    <!-- Lightning bolt (replaces V, connects E and D) — cyan with stroke -->
    <path
        android:fillColor="#29B6F6"
        android:strokeColor="#00BCD4"
        android:strokeWidth="2"
        android:strokeLineJoin="round"
        android:pathData="M497,315 L557,315 L524,395 L570,395 L494,525 L529,435 L474,435 Z" />

    <!-- Letter D: proper D shape (purple, even-odd fill) -->
    <path
        android:fillColor="#512DA8"
        android:fillType="evenOdd"
        android:pathData="M587,325 L587,515 L642,515 Q702,515 702,420 Q702,325 642,325 Z M611,349 L642,349 Q678,349 678,420 Q678,491 642,491 L611,491 Z" />

</vector>
