<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen logo — the actual EVDx app logo.

  Converted from public/logo.svg (the main brand logo used on the website).
  The logo is a dark rounded square (#2D2D2D) with white "EVD" letters
  and an integrated lightning bolt forming the V. The bolt "breathes"
  (opacity animation) in the web version, but we use a static version
  here for the splash — animations don't render reliably in windowBackground
  drawables.

  On the white splash background (#FFFFFF from splash_screen.xml), the dark
  rounded square is clearly visible and professional. This replaces the
  previous ic_splash_logo.xml which was just a standalone lightning bolt
  without the EVD wordmark.

  Source: public/logo.svg, viewBox 0 0 30 30.
  Vector drawable viewport: 30 x 30, sized at 108dp x 108dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="30"
    android:viewportHeight="30">

    <!-- Dark rounded square background with white stroke (the logo container) -->
    <path
        android:fillColor="#2D2D2D"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.6317"
        android:strokeMiterLimit="10"
        android:pathData="M24.51,28.51H5.49c-2.21,0-4-1.79-4-4V5.49c0-2.21,1.79-4,4-4h19.03c2.21,0,4,1.79,4,4v19.03 C28.51,26.72,26.72,28.51,24.51,28.51z" />

    <!-- EVD wordmark (white) — three paths forming E, the lightning-bolt V, and D -->

    <!-- Top-left arm of E -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M15.47,7.1l-1.3,1.85c-0.2,0.29-0.54,0.47-0.9,0.47h-7.1V7.09C6.16,7.1,15.47,7.1,15.47,7.1z" />

    <!-- Lightning bolt / V (the diagonal connecting E and D) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24.3,7.1 13.14,22.91 5.7,22.91 16.86,7.1" />

    <!-- Bottom-right arm of D -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M14.53,22.91l1.31-1.86c0.2-0.29,0.54-0.47,0.9-0.47h7.09v2.33H14.53z" />

</vector>
