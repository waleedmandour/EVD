        <domain includeSubdomains="false">192.168.49.100</domain>

        <!-- 172.16-31.x.x — private-use enterprise subnet (rare but seen) -->
        <domain includeSubdomains="false">172.16.0.1</domain>
        <domain includeSubdomains="false">172.16.0.10</domain>
        <domain includeSubdomains="false">172.16.0.50</domain>
