        <domain includeSubdomains="false">192.168.1.4</domain>
        <domain includeSubdomains="false">192.168.1.5</domain>
        <domain includeSubdomains="false">192.168.1.10</domain>
        <domain includeSubdomains="false">192.168.1.11</domain>
