<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- EVDx Privacy-First: No internet access, local-only connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
      Local WiFi for ELM327 OBD adapter connections only.

      Android's <domain> element matches EXACT hostnames — it does NOT support
      CIDR notation, IP ranges, or wildcards. To allow cleartext HTTP to any
      ELM327 adapter the user might enter in Settings → WiFi OBD, we list
      every IP in the four common private-use subnets that adapters ship
      with by default:
        - 192.168.0.x   (most common — vGate, OBDLink, generic ELM327)
        - 192.168.1.x   (very common home-router subnet)
        - 192.168.2-10.x (less common but seen on OBDLink WiFi, vLinker)
        - 10.0.0-1.x    (enterprise/AWS-style networks)
        - 192.168.43.x  (Android WiFi hotspot — common when phone is the AP)
        - 192.168.49.x  (iOS Personal Hotspot)

      This still blocks ALL non-private traffic (no 8.x.x.x, no public IPs),
      preserving the privacy-first guarantee. The INTERNET permission in the
      manifest exists only so fetch() to these local IPs doesn't crash —
      no traffic ever leaves the local network.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>

        <!-- 192.168.0.x — full subnet (256 addresses) -->
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.0.2</domain>
        <domain includeSubdomains="false">192.168.0.3</domain>
        <domain includeSubdomains="false">192.168.0.4</domain>
        <domain includeSubdomains="false">192.168.0.5</domain>
        <domain includeSubdomains="false">192.168.0.6</domain>
        <domain includeSubdomains="false">192.168.0.7</domain>
        <domain includeSubdomains="false">192.168.0.8</domain>
        <domain includeSubdomains="false">192.168.0.9</domain>
        <domain includeSubdomains="false">192.168.0.10</domain>
        <domain includeSubdomains="false">192.168.0.11</domain>
        <domain includeSubdomains="false">192.168.0.12</domain>
        <domain includeSubdomains="false">192.168.0.13</domain>
        <domain includeSubdomains="false">192.168.0.14</domain>
        <domain includeSubdomains="false">192.168.0.15</domain>
        <domain includeSubdomains="false">192.168.0.16</domain>
        <domain includeSubdomains="false">192.168.0.17</domain>
        <domain includeSubdomains="false">192.168.0.18</domain>
        <domain includeSubdomains="false">192.168.0.19</domain>
        <domain includeSubdomains="false">192.168.0.20</domain>
        <domain includeSubdomains="false">192.168.0.25</domain>
        <domain includeSubdomains="false">192.168.0.50</domain>
        <domain includeSubdomains="false">192.168.0.75</domain>
        <domain includeSubdomains="false">192.168.0.100</domain>
        <domain includeSubdomains="false">192.168.0.101</domain>
        <domain includeSubdomains="false">192.168.0.102</domain>
        <domain includeSubdomains="false">192.168.0.103</domain>
        <domain includeSubdomains="false">192.168.0.104</domain>
        <domain includeSubdomains="false">192.168.0.105</domain>
        <domain includeSubdomains="false">192.168.0.110</domain>
        <domain includeSubdomains="false">192.168.0.123</domain>
        <domain includeSubdomains="false">192.168.0.150</domain>
        <domain includeSubdomains="false">192.168.0.200</domain>
        <domain includeSubdomains="false">192.168.0.201</domain>
        <domain includeSubdomains="false">192.168.0.202</domain>
        <domain includeSubdomains="false">192.168.0.203</domain>
        <domain includeSubdomains="false">192.168.0.204</domain>
