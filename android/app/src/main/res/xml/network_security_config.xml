<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- EVDx Privacy-First: No internet access, local-only connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Local WiFi for ELM327 OBD adapter connections only -->
    <!-- Android domain matching is EXACT hostname, not subnet/CIDR. -->
    <!-- includeSubdomains does NOT work for IP addresses, only DNS hostnames. -->
    <!-- Each possible ELM327 adapter IP must be listed individually. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>

        <!-- ELM327 adapter common IPs — 192.168.0.x subnet -->
        <domain includeSubdomains="false">192.168.0.10</domain>
        <domain includeSubdomains="false">192.168.0.11</domain>
        <domain includeSubdomains="false">192.168.0.12</domain>
        <domain includeSubdomains="false">192.168.0.50</domain>
        <domain includeSubdomains="false">192.168.0.75</domain>
        <domain includeSubdomains="false">192.168.0.100</domain>
        <domain includeSubdomains="false">192.168.0.101</domain>
        <domain includeSubdomains="false">192.168.0.200</domain>

        <!-- ELM327 adapter common IPs — 192.168.1.x subnet -->
        <domain includeSubdomains="false">192.168.1.10</domain>
        <domain includeSubdomains="false">192.168.1.11</domain>
        <domain includeSubdomains="false">192.168.1.50</domain>
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.1.101</domain>

        <!-- ELM327 adapter common IPs — 192.168.2.x subnet -->
        <domain includeSubdomains="false">192.168.2.10</domain>
        <domain includeSubdomains="false">192.168.2.50</domain>
        <domain includeSubdomains="false">192.168.2.100</domain>

        <!-- ELM327 adapter common IPs — 10.0.x.x subnet -->
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.10</domain>
        <domain includeSubdomains="false">10.0.0.50</domain>
        <domain includeSubdomains="false">10.0.0.100</domain>
        <domain includeSubdomains="false">10.0.1.1</domain>

        <!-- ELM327 adapter common IPs — 192.168.5.x (some Chinese adapters) -->
        <domain includeSubdomains="false">192.168.5.1</domain>
        <domain includeSubdomains="false">192.168.5.10</domain>

        <!-- ELM327 adapter common IPs — 192.168.10.x (OBDLink WiFi) -->
        <domain includeSubdomains="false">192.168.10.1</domain>
        <domain includeSubdomains="false">192.168.10.10</domain>

        <!-- ELM327 adapter common IPs — 192.168.3.x (some vLinker) -->
        <domain includeSubdomains="false">192.168.3.1</domain>
        <domain includeSubdomains="false">192.168.3.10</domain>
    </domain-config>
</network-security-config>
