<?xml version="1.0" encoding="utf-8"?>
<!--
  Native Dashboard Layout (Hybrid Architecture)

  Comprehensive native dashboard for BYD head units. Shows all key vehicle
  data using native Android views — no WebView, no JavaScript, instant render.

  Layout: Landscape-optimized for 1920x720 BYD screen, but works on any size.
  Structure:
    - Top bar: connection status + DTC count
    - Center row: Speed (large) + SOC (circle) + key stats
    - Bottom row: battery details, tire pressures, motor data
    - Footer: Full App button (launches WebView)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true"
    tools:context=".NativeDashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ Top Bar: Connection Status + DTC Count ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- EVDx Logo + Title -->
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_splash_logo"
                android:contentDescription="EVDx" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="EVDx"
                android:textColor="#00D2FF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Connection Status -->
            <TextView
                android:id="@+id/connection_status_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecting..."
                android:textColor="#78909C"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />

            <!-- DTC Count -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DTCs: "
                    android:textColor="#78909C"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/dtc_count_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#00E676"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Center Row: Speed + SOC + Key Stats ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Speed (large, centered) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/speed_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— km/h"
                    android:textColor="#E8EAF6"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speed"
                    android:textColor="#78909C"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- SOC (with progress bar) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/soc_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—%"
                    android:textColor="#00E676"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <ProgressBar
                    android:id="@+id/soc_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="120dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#00D2FF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="State of Charge"
                    android:textColor="#78909C"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Power -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/power_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— kW"
                    android:textColor="#00D2FF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Power"
                    android:textColor="#78909C"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Range -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/range_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— km"
                    android:textColor="#00E676"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Range"
                    android:textColor="#78909C"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Battery Details (inline cards) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Battery Temp -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Battery Temp"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/battery_temp_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— °C"
                    android:textColor="#E8EAF6"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Motor Temp -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Motor Temp"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/motor_temp_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— °C"
                    android:textColor="#E8EAF6"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Ambient Temp -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ambient"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/ambient_temp_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— °C"
                    android:textColor="#E8EAF6"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Charging Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Charging"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/charging_status_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#78909C"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Electrical Details Row ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Pack Voltage -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pack Voltage"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/voltage_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— V"
                    android:textColor="#E8EAF6"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Pack Current -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pack Current"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/current_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— A"
                    android:textColor="#E8EAF6"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Cell Max V -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cell Max"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/cell_max_v_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— mV"
                    android:textColor="#E8EAF6"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Cell Min V -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cell Min"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/cell_min_v_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— mV"
                    android:textColor="#E8EAF6"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Odometer -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Odometer"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/odometer_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— km"
                    android:textColor="#E8EAF6"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Tire Pressures Row ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- FL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="10dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FL Tire"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tire_fl_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— kPa"
                    android:textColor="#E8EAF6"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- FR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="10dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FR Tire"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tire_fr_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— kPa"
                    android:textColor="#E8EAF6"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- RL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="10dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RL Tire"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tire_rl_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— kPa"
                    android:textColor="#E8EAF6"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- RR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1A2332"
                android:padding="10dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RR Tire"
                    android:textColor="#78909C"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tire_rr_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— kPa"
                    android:textColor="#E8EAF6"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Footer: Full App Button ═══ -->
        <Button
            android:id="@+id/full_app_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Open Full App (Diagnostics, AI, Reports)"
            android:textColor="#0D1117"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#00D2FF"
            android:visibility="gone" />

        <Button
            android:id="@+id/connect_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Connect OBD Adapter"
            android:textColor="#0D1117"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#00D2FF"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
