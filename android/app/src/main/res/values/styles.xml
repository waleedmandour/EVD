<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Fix #1 (Critical): windowBackground must NOT be @null/transparent.

      PREVIOUS BUG: AppTheme.NoActionBar set android:background=@null, making
      the window transparent during the transition from the launch theme
      (splash drawable) to the live WebView. On BYD DiLink 3.0 (Android 10),
      the compositor renders pure black behind transparent windows, so the
      user saw a black screen between the splash and the first React paint.

      FIX: Set android:windowBackground=@color/colorPrimaryDark on BOTH
      AppTheme and AppTheme.NoActionBar. This ensures the window always has
      a solid dark background, so even if the WebView takes a few seconds
      to paint, the user sees the app's dark brand color instead of black.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Fix #1: was android:background=@null (transparent) -> black screen.
             Now uses the same dark brand color so the window is never transparent. -->
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
    </style>

    <!--
      Splash screen launch theme.

      Uses @drawable/splash_screen (bright white background + dark vector logo)
      so the splash is visible immediately on app launch, before any Java code
      or WebView loads. parent=Theme.AppCompat.NoActionBar (NOT DayNight) so
      the splash is always light even when the system is in dark mode.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!--
      SplashTheme — explicit splash theme name referenced by SplashActivity.
      Same as AppTheme.NoActionBarLaunch; aliased here so the manifest can
      reference a clearly-named theme.
    -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
