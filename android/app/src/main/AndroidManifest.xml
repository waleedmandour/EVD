<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE Permissions for OBD adapter connectivity -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Location (required for BLE scan on Android 11 and below) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- WiFi for ELM327 OBD adapter connections (local network only) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Local network for WiFi ELM327 OBD adapters (192.168.x.x local connections only) -->
    <!-- App still makes ZERO cloud/telemetry/analytics connections -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Voice Assistant (TTS/STT) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock for background diagnostics -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ============================================================
         Fix B: Automotive permissions (BYD DiLink / Android Auto).
         These let the app query the CarPropertyManager for vehicle
         speed, powertrain, and energy data on cars that expose the
         Car SDK. On BYD DiLink 3.0 they are not strictly required
         (BYD exposes data via com.byd.auto.* instead), but declaring
         them lets the same APK run on AAOS / Android Auto head units.
         ============================================================ -->
    <uses-permission android:name="android.car.permission.CAR_SPEED" />
    <uses-permission android:name="android.car.permission.CAR_POWERTRAIN" />
    <uses-permission android:name="android.car.permission.CAR_ENERGY" />
    <!-- Overlay permission is needed on some automotive builds for the
         floating voice-assistant button. Even if not actively used,
         keeping it in the manifest avoids runtime SecurityException
         on AAOS builds that enforce the permission at install time. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- ============================================================
         Fix C: Mark the app as automotive-compatible.
         - android.hardware.type.automotive (required=false) lets the
           APK install on car head units that report this feature,
           without preventing installation on phones.
         - The <meta-data> tag below tells the BYD system / AAOS that
           the app is designed for automotive use and should not be
           killed immediately after the splash.
         ============================================================ -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="false" />

    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.wifi"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <!-- Touchscreen is optional so the APK can install on BYD head units
         that report as non-touch (some DiLink 3.0 builds do). -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!--
      Package visibility for BYD DiLink system apps (Android 11+).
      Without this <queries> block, PackageManager.getPackageInfo() throws
      NameNotFoundException for these packages even on a real BYD head unit,
      which prevents BYDAutoPlugin from detecting the vehicle.
      Reference: binti2 repo (waleedmandour/binti2) — same package list.
    -->
    <queries>
        <package android:name="com.byd.auto.ac" />
        <package android:name="com.byd.auto.navigation" />
        <package android:name="com.byd.auto.media" />
        <package android:name="com.byd.auto.settings" />
        <package android:name="com.byd.auto.phone" />
        <package android:name="com.byd.auto.launcher" />
        <package android:name="com.byd.auto.climate" />
        <package android:name="com.byd.auto.vehicleinfo" />
        <package android:name="com.byd.auto.energy" />
        <package android:name="com.byd.auto.camera" />
    </queries>

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="36">

        <!-- Fix C: Tell the BYD system / AAOS that this app is automotive-aware
             and should not be killed immediately after the splash. -->
        <meta-data
            android:name="com.android.automotive"
            android:value="true" />

        <!--
          SplashActivity — the new launcher activity (Fix A).

          Shows a bright white splash with the EVDx logo for at least
          1500 ms, then launches MainActivity. This replaces the previous
          approach where MainActivity was the launcher and the splash was
          only the launcher theme's windowBackground (which was dark and
          appeared as a black screen on BYD).

          Fix D: fullSensor orientation + configChanges covering all
          orientation/size changes so the activity is NOT recreated on
          rotation. BYD head units can rotate the screen at any time, and
          Activity recreation would destroy the WebView state.

          Fix E: android:exported="true" is REQUIRED for the launcher
          activity on Android 12+ (API 31+).
        -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/SplashTheme"
            android:launchMode="singleTask"
            android:screenOrientation="fullSensor"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize|uiMode|density|navigation|locale|layoutDirection|fontScale">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!--
          NativeDashboardActivity — native dashboard for BYD head units.

          Part of the Hybrid Architecture. On BYD head units, SplashActivity
          routes here instead of MainActivity. This activity shows vehicle
          data using native Android views (instant render, no WebView) and
          has a "Full App" button that launches MainActivity (WebView) for
          secondary features (diagnostics, AI, reports, settings).

          On non-BYD devices, SplashActivity skips this activity and goes
          directly to MainActivity — the native dashboard adds no value
          without BYD native data.

          exported="false" because this activity is only launched internally
          by SplashActivity, never from outside the app.
        -->
        <activity
            android:name=".NativeDashboardActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="fullSensor"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize|uiMode|density|navigation|locale|layoutDirection|fontScale"
            android:theme="@style/AppTheme.NoActionBarLaunch" />

        <!--
          MainActivity — the Capacitor WebView host.

          Fix D: fullSensor orientation (replaces the previous "portrait" /
          build-script-patched "sensorLandscape") so the activity rotates
          freely with the BYD screen. configChanges covers the full set so
          the activity is NOT recreated on rotation — WebView state is
          preserved, preventing black flashes during rotation.

          Fix E: android:exported="true" — required for any activity that
          other apps or the system can launch. MainActivity is launched
          only by SplashActivity (internal), so exported could be false,
          but keeping it true avoids issues on some OEM launchers.
        -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:screenOrientation="fullSensor">

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
